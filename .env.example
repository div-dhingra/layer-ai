# Database
DATABASE_URL=postgresql://user:password@localhost:5432/layer

# Redis
REDIS_URL=redis://localhost:6379

# AI Provider API Keys (platform keys for user completions)
LAYER_PLATFORM_OPENAI_API_KEY=sk-proj-your-openai-key-here
LAYER_PLATFORM_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
LAYER_PLATFORM_GOOGLE_API_KEY=your-google-api-key-here
LAYER_PLATFORM_MISTRAL_API_KEY=your-mistral-api-key-here

# Server
PORT=3001
NODE_ENV=development

# Authentication (generate a secure random string)
JWT_SECRET=your-jwt-secret-here

# Internal API (for sync:registry script)
INTERNAL_API_URL=http://localhost:3004
INTERNAL_API_KEY=your-internal-api-key-here
